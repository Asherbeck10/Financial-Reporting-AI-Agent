POSTGRES_USER=finreport
POSTGRES_PASSWORD=changeme
POSTGRES_DB=finreport_db

PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=changeme

ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

DATABASE_URL=postgresql+asyncpg://finreport:changeme@localhost:5432/finreport_db
UPLOAD_DIR=./uploads
DATA_ROWS_IN_PROMPT=100
MAX_UPLOAD_BYTES=20971520

VITE_API_BASE_URL=http://localhost:8000

# Firebase — backend (service account file goes in backend/firebase-service-account.json)
FIREBASE_PROJECT_ID=your-project-id

# Firebase — frontend (safe to expose, these are public config values)
VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id

# Production (set these when using docker-compose.prod.yml)
ENVIRONMENT=production
ALLOWED_ORIGINS=http://localhost
